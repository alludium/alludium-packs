{
  "kind": "project-type",
  "apiVersion": "alludium/v1alpha1",
  "key": "vc_origination_pipeline",
  "name": "VC Origination Pipeline",
  "description": "Project context for a standing venture sourcing pipeline that configures source coverage, credential readiness, review policy, and promotion thresholds before recurring sourcing work is enabled.",
  "projectSetup": {
    "setupLabel": "VC Origination Pipeline Setup",
    "starterId": "create-origination",
    "starterLabel": "Create Origination Setup",
    "starterResumeLabel": "Continue Origination Setup",
    "starterDescription": "Create or resume the VC Origination Pipeline setup flow.",
    "recommendedSetupAgent": "vc_origination_scout",
    "requiredEvidence": [
      "source_choice",
      "source_setup",
      "variables",
      "schedules"
    ],
    "setupSteps": [
      {
        "key": "source_choice",
        "label": "Choose sourcing route",
        "purpose": "Choose approved upstream origination sources such as Apify actors, Companies House public register previews, or manual source configuration.",
        "stepType": "source_choice",
        "evidenceKey": "source_choice",
        "required": true,
        "taskDefinitionSlug": "project-source-choice"
      },
      {
        "key": "source_setup",
        "label": "Setup sourcing sources",
        "purpose": "Review source readiness, actor or URL scope, budget policy, and read-preview boundaries without running sourcing.",
        "stepType": "source_setup",
        "evidenceKey": "source_setup",
        "required": true,
        "taskSelection": "sourceSetupTasks"
      },
      {
        "key": "variables",
        "label": "Review variables",
        "purpose": "Review thesis, source policy, budget, and review-threshold variables before activating the origination pipeline.",
        "stepType": "variables",
        "evidenceKey": "variables",
        "required": true,
        "taskDefinitionSlug": "project-variable-review"
      },
      {
        "key": "schedules",
        "label": "Configure sourcing schedules",
        "purpose": "Review optional recurring sourcing, digest, screening, and source-health tasks; all schedules stay disabled until explicitly approved.",
        "stepType": "schedules",
        "evidenceKey": "schedules",
        "required": true,
        "taskDefinitionSlug": "project-schedule-review"
      }
    ],
    "postApprovalActions": {
      "applyVariables": {
        "enabled": true,
        "label": "Apply reviewed origination variables",
        "sourceEvidenceKeys": ["variables"],
        "target": "workspace_and_project_setup_context",
        "actionMode": "platform_variable_application",
        "requiresReviewedUserApproval": true,
        "setupTasksMayPersistValues": false
      },
      "importProjects": {
        "enabled": false,
        "reason": "Origination setup configures an upstream sourcing pipeline. Deal Room creation happens later through an approved promotion task."
      },
      "inviteCollaborators": {
        "enabled": false,
        "reason": "Origination setup does not include an invite step. Collaborators can be invited through a separate project-membership action if needed."
      },
      "enableSchedules": {
        "enabled": true,
        "label": "Enable approved origination schedules",
        "sourceEvidenceKeys": ["schedules"],
        "target": "configuredProject",
        "scheduleGroupsRef": "projectSetup.scheduleGroups",
        "defaultEnabled": false,
        "requiresReviewedUserApproval": true,
        "setupTasksMayEnableRecurringSync": false
      }
    },
    "scheduleGroups": [
      {
        "key": "core_sourcing",
        "label": "Core sourcing loop",
        "description": "Primary recurring sourcing pass, digest, and source-health review for the origination pipeline.",
        "taskDefinitionSlugs": [
          "run-sourcing-pipeline",
          "generate-sourcing-digest",
          "review-source-errors-and-spend"
        ],
        "defaultExpanded": true,
        "advanced": false
      },
      {
        "key": "source_discovery",
        "label": "Source-specific discovery",
        "description": "Optional source-level discovery schedules for approved public and paid source surfaces.",
        "taskDefinitionSlugs": [
          "discover-companies-house-candidates",
          "discover-x-founder-signals",
          "discover-github-builder-signals",
          "discover-linkedin-founders",
          "discover-reddit-builder-signals"
        ],
        "defaultExpanded": false,
        "advanced": true
      },
      {
        "key": "review_and_engagement",
        "label": "Review and engagement prep",
        "description": "Optional review, screening, portfolio-overlap, and outreach-draft tasks that operate on approved candidate batches.",
        "taskDefinitionSlugs": [
          "review-portfolio-overlap",
          "screen-active-sourcing-candidates",
          "prepare-outreach-draft-queue"
        ],
        "defaultExpanded": false,
        "advanced": true
      },
      {
        "key": "spend_controls",
        "label": "Spend controls",
        "description": "Optional recurring paid-source spend audit for LinkedIn/Apify query management.",
        "taskDefinitionSlugs": ["audit-linkedin-query-spend"],
        "defaultExpanded": false,
        "advanced": true
      }
    ],
    "defaultChildTask": {
      "label": "Setup source",
      "taskDefinitionSlug": "project-source-setup",
      "setupGoal": "Review the selected origination source route, discovery scope, source policy, and schedule intent before any run or write."
    },
    "variableDiscoveryTask": {
      "label": "VC Variable Discovery",
      "taskDefinitionTemplateId": "vc.pack_variable_discovery",
      "taskDefinitionSlug": "vc-pack-variable-discovery"
    },
    "sourceSetupTasks": [
      {
        "applicationRecommendationId": "apify-actors-mcp",
        "applicationExternalId": "apify-actors-mcp",
        "label": "Set Up Apify for VC Origination",
        "setupGoal": "Confirm Apify connection readiness, actor allowlist, source scope, and read-preview policy for this origination pipeline.",
        "taskDefinitionTemplateId": "vc.apify_setup",
        "taskDefinitionSlug": "apify-setup"
      },
      {
        "applicationRecommendationId": "firecrawl-mcp-hosted",
        "applicationExternalId": "firecrawl-mcp-hosted",
        "label": "Configure Companies House public register preview",
        "setupGoal": "Confirm Companies House public-register source scope and read-preview policy for this origination pipeline.",
        "taskDefinitionTemplateId": "vc.companies_house_setup",
        "taskDefinitionSlug": "companies-house-setup"
      }
    ]
  },
  "initialVersion": {
    "version": "0.1.1",
    "documentLibrary": {
      "catalogPath": "alludium/documents/catalog.v1.json",
      "documentIds": [
        "vc.document.investment_screening_framework",
        "vc.document.investment_diligence_question_framework",
        "vc.document.evidence_citation_style_guide",
        "vc.document.file_naming_source_index_sop",
        "vc.document.origination_pipeline_sop",
        "vc.document.source_registry_template",
        "vc.document.candidate_batch_template",
        "vc.document.sourcing_scoring_rubric",
        "vc.document.source_health_review_checklist",
        "vc.document.paid_source_spend_audit_checklist",
        "vc.document.sourcing_digest_template",
        "vc.document.outreach_queue_template",
        "vc.document.promotion_package_template",
        "vc.document.dedupe_novelty_policy",
        "vc.document.apify_source_setup_checklist",
        "vc.document.companies_house_source_setup_checklist"
      ]
    },
    "fieldsSchema": [
      {
        "id": "field-pipeline-name",
