    "projectTaskMappings": [
      {
        "id": "mapping-configure-origination-pipeline",
        "taskDefinitionSlug": "configure-origination-pipeline",
        "taskDefinitionTemplateId": "vc.configure_origination_pipeline",
        "lifecycleStage": "draft",
        "projectScope": "project_instance",
        "activationPolicy": {
          "mode": "manual_review",
          "autoStartWhenRequiredInputsAvailable": false,
          "requiresHumanApproval": true,
          "createTaskWhenLifecycleStageEntered": false
        },
        "inputMappings": [
          {
            "taskField": "configuration_goal",
            "source": "constant",
            "constantValue": "Configure thesis, source scope, cadence, budget, review policy, and credential-readiness boundaries for this VC origination pipeline.",
            "requiredForActivation": true
          },
          {
            "taskField": "current_pipeline_context",
            "source": "project.id",
            "requiredForActivation": false
          }
        ],
        "outputMappings": [
          {
            "taskField": "source_registry",
            "target": "project.field",
            "targetPath": "source_registry"
          },
          {
            "taskField": "review_policy",
            "target": "project.field",
            "targetPath": "review_policy"
          }
        ]
      },
      {
        "id": "mapping-run-sourcing-pipeline",
        "taskDefinitionSlug": "run-sourcing-pipeline",
        "taskDefinitionTemplateId": "vc.run_sourcing_pipeline",
        "lifecycleStage": "active",
        "projectScope": "project_instance",
        "activationPolicy": {
          "mode": "manual_review",
          "autoStartWhenRequiredInputsAvailable": false,
          "requiresHumanApproval": true,
          "createTaskWhenLifecycleStageEntered": false
        },
        "inputMappings": [
          {
            "taskField": "sourcing_run_scope",
            "source": "project.field",
            "sourcePath": "source_registry",
            "requiredForActivation": true
          },
          {
            "taskField": "run_mode",
            "source": "constant",
            "constantValue": "dry_run_or_manual",
            "requiredForActivation": false
          }
        ],
        "outputMappings": [
          {
            "taskField": "run_status",
            "target": "project.field",
            "targetPath": "last_run_status"
          },
          {
            "taskField": "new_candidates_count",
            "target": "project.field",
            "targetPath": "new_candidates_last_run"
          },
